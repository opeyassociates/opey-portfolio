---
---
<header>
  <nav class="container">
    <a href="#hero" class="logo" aria-label="Opey Theophilus">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="40" height="40" fill="#1a1917"/>
        <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle"
          fill="white" font-family="Georgia, serif" font-size="14" font-weight="400" letter-spacing="1">OT</text>
      </svg>
    </a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#education">Education</a></li>
      <li><a href="#awards">Awards</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <a href="/cv.pdf" class="cv-btn" download>Download CV</a>
    <button class="menu-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
  <div class="mobile-menu">
    <ul>
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#education">Education</a></li>
      <li><a href="#awards">Awards</a></li>
      <li><a href="#contact">Contact</a></li>
      <li><a href="/cv.pdf" download>Download CV</a></li>
    </ul>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--light-gray);
    transition: box-shadow 0.3s;
  }

  header.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.06); }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .logo svg { display: block; }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 32px;
  }

  .nav-links a {
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--dark-gray);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--black); }

  .cv-btn {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 20px;
    border: 1px solid var(--black);
    color: var(--black);
    transition: background 0.2s, color 0.2s;
  }

  .cv-btn:hover { background: var(--black); color: var(--white); }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--black);
    transition: transform 0.3s;
  }

  .mobile-menu {
    display: none;
    padding: 24px;
    border-top: 1px solid var(--light-gray);
  }

  .mobile-menu ul { list-style: none; }

  .mobile-menu li { padding: 12px 0; border-bottom: 1px solid var(--light-gray); }

  .mobile-menu a { font-size: 15px; color: var(--dark-gray); }

  @media (max-width: 900px) {
    .nav-links, .cv-btn { display: none; }
    .menu-toggle { display: flex; }
    .mobile-menu.open { display: block; }
  }
</style>

<script>
  const header = document.querySelector('header');
  const toggle = document.querySelector('.menu-toggle');
  const mobileMenu = document.querySelector('.mobile-menu');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  });

  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });

  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });
</script>
