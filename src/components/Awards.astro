---
const awards = [
  {
    title: "Barbados CARIFESTA Pavilion Competition",
    org: "Adjaye Associates",
    year: "2025",
    description: "International pavilion design competition in collaboration with Adjaye Associates. Served as Team Lead & Visualiser, developing the full visual identity and competition submission.",
    type: "Competition",
  },
  {
    title: "Kaira Looro Architecture Competition",
    org: "Kaira Looro Organization",
    year: "2024",
    description: "Humanitarian architecture competition for a nursery facility in rural Casamance, Senegal. Served as Team Lead & Visualiser, managing concept development through final presentation.",
    type: "Competition",
  },
];

const publications = [
  {
    title: "Non-Domestic Design — Hohuriya Market Pavilion",
    year: "2025",
    description: "Parametric market pavilion design project exploring traditional typologies through computational form-finding and contemporary material systems.",
    type: "Academic Project",
  },
  {
    title: "Dine with Nature — Restaurant Redesign",
    year: "2025",
    description: "Restaurant renovation project proposing nature as the primary dining experience, with spatial planning, demolition proposals, and phased intervention strategies.",
    type: "Academic Project",
  },
];
---

<section id="awards">
  <div class="container">
    <div class="awards-layout">
      <div>
        <p class="section-label">Recognition</p>
        <h2 class="section-title">Awards &<br/>Competitions</h2>
        <div class="awards-list">
          {awards.map(award => (
            <div class="award-item">
              <div class="award-left">
                <span class="award-year">{award.year}</span>
                <span class="award-type">{award.type}</span>
              </div>
              <div class="award-right">
                <h3 class="award-title">{award.title}</h3>
                <p class="award-org">{award.org}</p>
                <p class="award-desc">{award.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <p class="section-label">Research</p>
        <h2 class="section-title" style="font-size: 2rem;">Publications &<br/>Research</h2>
        <div class="awards-list">
          {publications.map(pub => (
            <div class="award-item">
              <div class="award-left">
                <span class="award-year">{pub.year}</span>
                <span class="award-type">{pub.type}</span>
              </div>
              <div class="award-right">
                <h3 class="award-title">{pub.title}</h3>
                <p class="award-desc">{pub.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="certifications">
          <p class="section-label" style="margin-top: 48px;">Training</p>
          <ul class="cert-list">
            <li>OA ArchViz Academy — Architectural Visualization</li>
            <li>Hanex Construction Ltd. — Architecture Internship</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #awards { }

  .awards-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .awards-list { display: flex; flex-direction: column; gap: 0; }

  .award-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--light-gray);
  }

  .award-item:first-child { border-top: 1px solid var(--light-gray); }

  .award-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 2px;
  }

  .award-year {
    font-size: 13px;
    font-weight: 500;
    color: var(--black);
  }

  .award-type {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .award-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--black);
    margin-bottom: 4px;
  }

  .award-org {
    font-size: 12px;
    color: var(--mid-gray);
    margin-bottom: 8px;
  }

  .award-desc {
    font-size: 13px;
    color: var(--dark-gray);
    line-height: 1.6;
  }

  .cert-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cert-list li {
    font-size: 13px;
    color: var(--dark-gray);
    padding-left: 16px;
    position: relative;
  }

  .cert-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .awards-layout { grid-template-columns: 1fr; gap: 60px; }
  }
</style>
