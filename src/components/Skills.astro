---
const skillGroups = [
  {
    category: "Design & Drafting",
    skills: [
      { name: "AutoCAD", level: 95 },
      { name: "Revit (BIM)", level: 85 },
      { name: "SketchUp", level: 90 },
      { name: "Rhino 3D", level: 75 },
    ],
  },
  {
    category: "3D & Visualization",
    skills: [
      { name: "3ds Max", level: 88 },
      { name: "D5 Render", level: 92 },
      { name: "Lumion", level: 80 },
      { name: "Chaos Vantage", level: 75 },
      { name: "Unreal Engine", level: 65 },
    ],
  },
  {
    category: "Post-Production",
    skills: [
      { name: "Adobe Photoshop", level: 90 },
      { name: "Adobe Illustrator", level: 80 },
      { name: "CorelDRAW", level: 85 },
      { name: "Canva", level: 88 },
    ],
  },
  {
    category: "Computational & AI",
    skills: [
      { name: "Grasshopper", level: 65 },
      { name: "Dynamo", level: 60 },
      { name: "AI Visualization", level: 80 },
      { name: "ComfyUI", level: 70 },
    ],
  },
];
---

<section id="skills">
  <div class="container">
    <p class="section-label">Expertise</p>
    <h2 class="section-title">Skills & Tools</h2>
    <div class="skills-grid">
      {skillGroups.map(group => (
        <div class="skill-group">
          <h3 class="group-title">{group.category}</h3>
          <ul class="skill-list">
            {group.skills.map(skill => (
              <li class="skill-item">
                <div class="skill-header">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-pct">{skill.level}%</span>
                </div>
                <div class="skill-bar">
                  <div class="skill-fill" style={`width: ${skill.level}%`}></div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="software-logos">
      <p class="section-label" style="margin-bottom: 32px;">Also proficient in</p>
      <div class="logo-row">
        {["Fusion 360", "Topaz Gigapixel AI", "Artios CAD", "Microsoft Office Suite", "Azure Data Studio"].map(tool => (
          <div class="tool-chip">{tool}</div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #skills { background: var(--off-white); }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 60px 80px;
    margin-bottom: 80px;
  }

  .group-title {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 28px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--light-gray);
  }

  .skill-list { list-style: none; display: flex; flex-direction: column; gap: 18px; }

  .skill-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .skill-name { font-size: 14px; color: var(--dark-gray); }
  .skill-pct { font-size: 12px; color: var(--mid-gray); }

  .skill-bar {
    height: 2px;
    background: var(--light-gray);
    position: relative;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    background: var(--black);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s ease;
  }

  .skill-fill.animated { transform: scaleX(1); }

  .logo-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tool-chip {
    padding: 8px 18px;
    border: 1px solid var(--light-gray);
    font-size: 12px;
    color: var(--dark-gray);
    background: var(--white);
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .skills-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

<script>
  const fills = document.querySelectorAll('.skill-fill');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
      }
    });
  }, { threshold: 0.1 });

  fills.forEach(fill => observer.observe(fill));
</script>
