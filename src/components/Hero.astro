---
---
<section id="hero">
  <div class="hero-inner container">
    <div class="hero-text">
      <p class="section-label">Architecture & Design</p>
      <h1>
        <span class="name">Opey<br/>Theophilus</span>
        <span class="tagline">Designing spaces<br/><em>that tell stories.</em></span>
      </h1>
      <p class="hero-desc">
        Architect and visual storyteller — blending spatial design, computational thinking, and immersive visualization to craft environments that resonate.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">View Work</a>
        <a href="#contact" class="btn-secondary">Get in Touch</a>
      </div>
    </div>
    <div class="hero-image">
      <div class="image-placeholder">
        <span>Hero Image</span>
      </div>
      <div class="hero-badge">
        <svg viewBox="0 0 100 100" width="100" height="100">
          <path id="circlePath" d="M 50,50 m -37,0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="none"/>
          <text font-size="11" letter-spacing="3" fill="var(--mid-gray)" font-family="Inter, sans-serif">
            <textPath href="#circlePath">ARCHITECTURE · VISUALIZATION · DESIGN ·</textPath>
          </text>
        </svg>
      </div>
    </div>
  </div>
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 72px;
    background: var(--white);
    position: relative;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  h1 {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 28px;
  }

  .name {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--black);
  }

  .tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 400;
    color: var(--mid-gray);
    line-height: 1.3;
  }

  .tagline em { color: var(--accent); font-style: italic; }

  .hero-desc {
    font-size: 15px;
    color: var(--dark-gray);
    max-width: 420px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 14px 32px;
    background: var(--black);
    color: var(--white);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.2s;
  }

  .btn-primary:hover { background: var(--dark-gray); }

  .btn-secondary {
    padding: 14px 32px;
    border: 1px solid var(--light-gray);
    color: var(--dark-gray);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover { border-color: var(--black); color: var(--black); }

  .hero-image {
    position: relative;
    aspect-ratio: 4/5;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mid-gray);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-badge {
    position: absolute;
    bottom: -20px;
    right: -20px;
    animation: spin 20s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--mid-gray);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--mid-gray), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-image { aspect-ratio: 16/9; }
    .hero-badge { display: none; }
    .hero-scroll { display: none; }
  }
</style>
