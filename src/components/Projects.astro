---
const projects = [
  {
    id: 1,
    title: "Come and Relax",
    category: "Architectural Design",
    year: "2025",
    image: "/images/popup-retail.jpg",
    description: "A pop-up retail stall designed to function as both a commercial space and a relaxation environment, inspired by the biomimetic form of a millipede.",
    tags: ["3ds Max", "D5 Render", "Rhino"],
    featured: true,
  },
  {
    id: 2,
    title: "NWL Apartment",
    category: "Architectural Visualization",
    year: "2024",
    image: "/images/nwl-apartment.jpg",
    description: "Night-time photorealistic visualization of a contemporary two-storey residential building, showcasing warm lighting and clean modern façade detailing.",
    tags: ["D5 Render", "3ds Max", "Photoshop"],
    featured: true,
  },
  {
    id: 3,
    title: "Francisca's Estate Gate",
    category: "Architectural Visualization",
    year: "2024",
    image: "/images/franciscas-estate.jpg",
    description: "Atmospheric dusk rendering of a gated estate entrance with warm ambient lighting, stone cladding, and landscape integration.",
    tags: ["D5 Render", "Photoshop"],
    featured: false,
  },
  {
    id: 4,
    title: "Kitchen Interior",
    category: "Interior Design",
    year: "2024",
    image: "/images/kitchen-interior.jpg",
    description: "High-end kitchen interior visualization featuring dark matte cabinetry, marble surfaces, and carefully composed natural lighting.",
    tags: ["D5 Render", "3ds Max", "Corona"],
    featured: false,
  },
  {
    id: 5,
    title: "Kaira Looro — Tere Nursery",
    category: "Architecture Competition",
    year: "2025",
    image: "/images/kaira-looro.jpg",
    description: "Contextually rooted nursery facility designed for a rural village in Casamance, southern Senegal, where access to resources is limited. Team Lead & Visualiser.",
    tags: ["Revit", "D5 Render", "AutoCAD"],
    featured: true,
  },
  {
    id: 6,
    title: "Fidelity Residence",
    category: "Architectural Visualization",
    year: "2024",
    image: "/images/fidelity-house.jpg",
    description: "Aerial perspective rendering of a single-storey residential compound in Ghana, emphasizing site integration and functional layout.",
    tags: ["D5 Render", "3ds Max", "Photoshop"],
    featured: false,
  },
  {
    id: 7,
    title: "Modern Residence — Exterior",
    category: "Architectural Visualization",
    year: "2024",
    image: "/images/house-exterior.jpg",
    description: "Daytime exterior visualization of a contemporary two-storey home featuring full-height glazing, clean volumes, and tropical landscaping.",
    tags: ["D5 Render", "3ds Max"],
    featured: false,
  },
  {
    id: 8,
    title: "Immanuel Office Interior",
    category: "Interior Design",
    year: "2024",
    image: "/images/immanuel-interior.jpg",
    description: "Professional office interior with warm wood flooring, exposed brick accent wall, recessed ceiling lighting, and ergonomic workstation layout.",
    tags: ["D5 Render", "3ds Max", "Photoshop"],
    featured: false,
  },
];

const categories = ["All", ...new Set(projects.map(p => p.category))];
---

<section id="projects">
  <div class="container">
    <p class="section-label">Selected Work</p>
    <h2 class="section-title">Projects</h2>

    <div class="filter-bar">
      {categories.map((cat, i) => (
        <button class={`filter-btn ${i === 0 ? 'active' : ''}`} data-filter={cat}>
          {cat}
        </button>
      ))}
    </div>

    <div class="projects-grid" id="projects-grid">
      {projects.map((project) => (
        <article class="project-card" data-category={project.category}>
          <div class="project-image">
            <img src={project.image} alt={project.title} loading="lazy" />
            <div class="project-overlay">
              <div class="overlay-tags">
                {project.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </div>
          <div class="project-info">
            <div class="project-meta">
              <span class="project-category">{project.category}</span>
              <span class="project-year">{project.year}</span>
            </div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .filter-bar {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .filter-btn {
    padding: 8px 20px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--light-gray);
    color: var(--mid-gray);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }

  .filter-btn:hover, .filter-btn.active {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 32px;
  }

  .project-card { cursor: pointer; }

  .project-card:nth-child(4n+1):not(:nth-child(3n+1)) {
    grid-column: span 1;
  }

  .project-card[data-category]:first-child,
  .project-card:nth-child(4) {
    grid-column: span 2;
  }

  .project-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .project-card:first-child .project-image,
  .project-card:nth-child(4) .project-image {
    aspect-ratio: 16/9;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .project-card:hover .project-image img { transform: scale(1.03); }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26,25,23,0.6);
    opacity: 0;
    transition: opacity 0.3s;
    display: flex;
    align-items: flex-end;
    padding: 20px;
  }

  .project-card:hover .project-overlay { opacity: 1; }

  .overlay-tags { display: flex; gap: 8px; flex-wrap: wrap; }

  .tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(255,255,255,0.15);
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.3);
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .project-category {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .project-year {
    font-size: 11px;
    color: var(--mid-gray);
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    margin-bottom: 8px;
    color: var(--black);
  }

  .project-desc {
    font-size: 13px;
    color: var(--dark-gray);
    line-height: 1.6;
  }

  .project-card.hidden { display: none; }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: 1fr 1fr; }
    .project-card:first-child,
    .project-card:nth-child(4) { grid-column: span 2; }
  }

  @media (max-width: 600px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-card:first-child,
    .project-card:nth-child(4) { grid-column: span 1; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        const match = filter === 'All' || card.dataset.category === filter;
        card.classList.toggle('hidden', !match);
      });
    });
  });
</script>
